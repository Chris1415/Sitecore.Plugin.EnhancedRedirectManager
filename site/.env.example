# Redirect Manager — environment variables
# Copy this file to .env.local and adjust as needed.
# All NEXT_PUBLIC_* variables are inlined at build time.

# Theme switcher visibility.
# - Unset or "false" (default): switcher is hidden; theme follows the operator's
#   OS prefers-color-scheme. The "d" hotkey is also disabled.
# - "true": renders a Light / Dark / System dropdown in each surface's chrome
#   AND enables the "d" hotkey to toggle Light ↔ Dark.
NEXT_PUBLIC_REDIRECT_MANAGER_THEME_SWITCHER=false

# --- PRD-003 Publish (Branch B — server-side OAuth proxy) ---
# Automation client credentials for the SitecoreAI Publishing API.
# SERVER-ONLY — never prefix these with NEXT_PUBLIC_.
# Source: Cloud Portal → your tenant → Settings → Automation clients.
# Create a client with scopes: xmcloud.cm:admin + read (:r) + write (:w).
# The secret is shown ONCE — copy it immediately.
SITECORE_PUBLISH_CLIENT_ID=your-automation-client-id-here
SITECORE_PUBLISH_CLIENT_SECRET=your-automation-client-secret-here

# --- OPTIONAL OVERRIDES (all three default to Sitecore-managed canonical hosts;
# you do NOT need these in .env.local for standard tenants) ---
#
# OAuth token endpoint — default https://auth.sitecorecloud.io/oauth/token
# Only set if you are on a non-standard Sitecore Cloud region.
# SITECORE_OAUTH_TOKEN_URL=
#
# OAuth audience — default https://api.sitecorecloud.io
# Only set if Sitecore docs explicitly tell you to.
# (Note: MUST be exactly "https://api.sitecorecloud.io" — no trailing slash,
#  no substitution with the API base URL, or you will get 401.)
# SITECORE_OAUTH_AUDIENCE=
#
# Publishing API base URL — default https://edge-platform.sitecorecloud.io
# This is the Sitecore-managed proxy host for ALL tenants; the path prefix
# (/authoring/publishing/v1/...) is the routing key. Only set for non-standard
# regions or local tunnels.
# SITECORE_PUBLISHING_BASE_URL=
